# ============================================
# Noor Studio — Environment Variables
# ============================================
#
# STEP 1: Copy this file to .env (in the project root):
#   cp .env.example .env
#
# STEP 2: Get your FREE email API key:
#   1. Go to https://web3forms.com
#   2. Enter your email (the one you want booking alerts sent to)
#   3. You'll receive an Access Key in your inbox
#   4. Paste it below
#
# STEP 3: Restart the dev server:
#   npm run dev
# ============================================

# Email Notifications (Web3Forms - FREE)
# Get key at: https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here
